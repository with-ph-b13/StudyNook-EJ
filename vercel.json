{
  "version": 2,
  "builds": [
    {
      "src": "studynook-client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "studynook-server/src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "studynook-server/src/index.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "studynook-client/index.html" }
  ]
}
