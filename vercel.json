{
  "version": 2,
  "builds": [
    {
      "src": "studynook-server/src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["studynook-server/public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "studynook-server/src/index.js"
    }
  ]
}
